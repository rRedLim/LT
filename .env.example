# Скопируйте в `.env` и при необходимости поправьте:
#   cp .env.example .env

# Порт, на котором будет доступен веб-интерфейс
LENTA_PORT=7860

# Базовая мультимодальная модель (HF id). Скачивается в hf-cache volume.
LENTA_BASE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# 4-bit (NF4) загрузка VLM. Ставьте 1 на GPU < ~16 ГБ
# (напр. RTX 4070 Super 12 ГБ) — 7B ужмётся с ~16 ГБ до ~6 ГБ.
# На боевом GPU-сервере оставьте 0 (или не задавайте) — будет bf16.
LENTA_VLM_4BIT=0

# Токен HuggingFace — нужен только если базовая модель приватная или
# упираетесь в rate-limit анонимной загрузки. Иначе оставьте пустым.
HUGGING_FACE_HUB_TOKEN=
